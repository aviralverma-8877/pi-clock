[Unit]
Description=Nokia 5110 LCD based clock and system monitor
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/pi-clock/
Environment=ASST_ENABLED=1
Environment=ASST_BACKEND=ollama
Environment=OLLAMA_HOST=192.168.1.30
Environment=OLLAMA_MODEL=deepseek-coder-v2:latest
Environment=GEMINI_API_KEY=
Environment=GEMINI_MODEL=gemini-2.5-flash-lite
ExecStart=/usr/bin/python3 /root/pi-clock/main
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target