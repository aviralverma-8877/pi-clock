#!/usr/bin/env python3

import time
import adafruit_pcd8544
import board
import busio
import digitalio
from PIL import Image, ImageDraw, ImageFont
from functions.funct import function

spi = busio.SPI(board.SCK, MOSI=board.MOSI)
dc = digitalio.DigitalInOut(board.D23)
cs = digitalio.DigitalInOut(board.CE0)
reset = digitalio.DigitalInOut(board.D24)
backlight = digitalio.DigitalInOut(board.D22)
backlight.switch_to_output()
backlight.value = False

display = adafruit_pcd8544.PCD8544(spi, dc, cs, reset)
display.bias = 5
contr = 48
display.contrast = contr
display.invert = True
display.fill(1)
display.show()

prev_btn = digitalio.DigitalInOut(board.D27)
next_btn = digitalio.DigitalInOut(board.D18)
yes_btn = digitalio.DigitalInOut(board.D17)
no_btn = digitalio.DigitalInOut(board.D25)

prev_btn.switch_to_input(pull=digitalio.Pull.UP)
next_btn.switch_to_input(pull=digitalio.Pull.UP)
yes_btn.switch_to_input(pull=digitalio.Pull.UP)
no_btn.switch_to_input(pull=digitalio.Pull.UP)

functions = function(prev_btn, next_btn, yes_btn, no_btn, backlight, display, contr)

MENU = [
    "Time",
    "Date",
    "Upgrade",
    "Network",
    "Temperature",
    "CPU",
    "RAM",
    "Disk",
    "Backlight",
    "Contrast",
    "Volume",
    "Shutdown",
    "Restart",
]

IMG_FILES = [
    "time.bmp",
    "calendar.bmp",
    "upgrade.bmp",
    "network.bmp",
    "temperature.bmp",
    "cpu.bmp",
    "ram.bmp",
    "disk.bmp",
    "bkled.bmp",
    "contrast.bmp",
    "volume.bmp",
    "shutdown.bmp",
    "restart.bmp",
]

# How often each screen refreshes (seconds)
UPDATE_INTERVALS = [
    1.0,   # Time
    60.0,  # Date
    5.0,   # Upgrade
    5.0,   # Network
    2.0,   # Temperature
    2.0,   # CPU
    2.0,   # RAM
    10.0,  # Disk
    30.0,  # Backlight
    30.0,  # Contrast
    30.0,  # Volume
    30.0,  # Shutdown
    30.0,  # Restart
]

# Screens where holding yes/no auto-repeats (contrast and volume)
AUTO_REPEAT_SCREENS = {9, 10}

DEBOUNCE    = 0.05   # minimum seconds between button events
REPEAT_DELAY = 0.40  # seconds held before first auto-repeat
REPEAT_RATE  = 0.12  # seconds between subsequent repeats

print("Loading images...")
cached_images = []
for img_file in IMG_FILES:
    img = Image.open("images/" + img_file).resize(
        (display.width, display.height),
        Image.Resampling.LANCZOS
    ).convert("1")
    cached_images.append(img)

font = ImageFont.truetype("fonts/EnterCommand.ttf", 15)

FUNC_MAP = [
    functions.get_time,
    functions.get_date,
    functions.sys_upgrade,
    functions.get_ip,
    functions.get_cpu_temperature,
    functions.get_cpu,
    functions.get_ram,
    functions.get_disk,
    functions.toggleBkled,
    functions.set_contrast,
    functions.set_volume,
    functions.shutdown,
    functions.restart,
]


def _centered_x(draw, text, font, width):
    bbox = draw.textbbox((0, 0), text, font=font)
    return max(0, (width - (bbox[2] - bbox[0])) // 2)


def render(option, msg, body):
    image = cached_images[option].copy()
    draw = ImageDraw.Draw(image)

    # Right column starts at x=25 (left side reserved for background icon)
    RIGHT_X = 25
    right_w = display.width - RIGHT_X  # 59 px

    # Title — centered in right column
    tbbox = draw.textbbox((0, 0), MENU[option], font=font)
    tx = RIGHT_X + max(0, (right_w - (tbbox[2] - tbbox[0])) // 2)
    draw.text((tx, 1), MENU[option], font=font)
    title_bottom = 1 + (tbbox[3] - tbbox[1])  # actual rendered height

    # Main data — centred in right column, 3 px below title
    if msg:
        mbbox = draw.textbbox((0, 0), msg, font=font)
        mx = RIGHT_X + max(0, (right_w - (mbbox[2] - mbbox[0])) // 2)
        draw.text((mx, title_bottom + 3), msg, font=font)

    # Action bar — left-aligned at the bottom
    draw.text((0, 34), body, font=font)

    display.image(image)
    display.show()


option = 0
command = "nav"
last_update_time = 0.0
last_content = (None, None)

btn_active   = {k: False for k in ("prev", "next", "yes", "no")}
btn_down_at  = {k: 0.0   for k in ("prev", "next", "yes", "no")}
last_evt_at  = {k: 0.0   for k in ("prev", "next", "yes", "no")}
last_rep_at  = {k: 0.0   for k in ("yes",  "no")}

BTN_PINS = {
    "prev": prev_btn,
    "next": next_btn,
    "yes":  yes_btn,
    "no":   no_btn,
}

print("Starting main loop...")
while True:
    now = time.time()
    needs_update = False
    nav_changed  = False

    # --- Button handling ---
    for name, pin in BTN_PINS.items():
        pressed = not pin.value
        was     = btn_active[name]

        if pressed and not was:
            btn_active[name]  = True
            btn_down_at[name] = now
            if now - last_evt_at[name] >= DEBOUNCE:
                last_evt_at[name] = now
                if name == "next":
                    option = (option + 1) % len(MENU)
                    command = "nav"
                    functions.last_comm = "no"
                    nav_changed = True
                elif name == "prev":
                    option = (option - 1) % len(MENU)
                    command = "nav"
                    functions.last_comm = "no"
                    nav_changed = True
                elif name in ("yes", "no"):
                    command = name
                needs_update = True
        elif not pressed and was:
            btn_active[name] = False

    # Auto-repeat while holding yes/no on adjustable screens
    if option in AUTO_REPEAT_SCREENS:
        for name in ("yes", "no"):
            if btn_active[name]:
                held = now - btn_down_at[name]
                if held >= REPEAT_DELAY and now - last_rep_at[name] >= REPEAT_RATE:
                    command = name
                    needs_update = True
                    last_rep_at[name] = now

    # Periodic refresh
    if now - last_update_time >= UPDATE_INTERVALS[option]:
        needs_update = True

    # --- Render ---
    if needs_update:
        msg, body = FUNC_MAP[option](command)
        if (msg, body) != last_content or nav_changed:
            render(option, msg, body)
            last_content = (msg, body)
        last_update_time = now
        command = "nav"  # consumed; auto-repeat will re-set if still held

    time.sleep(0.01)  # 10 ms — snappy button response, low CPU idle
