#!/usr/bin/env python3

import time
import psutil
import adafruit_pcd8544
import board
import busio
import digitalio
from PIL import Image, ImageDraw, ImageFont
from functions.funct import function

spi = busio.SPI(board.SCK, MOSI=board.MOSI)
dc = digitalio.DigitalInOut(board.D23)
cs = digitalio.DigitalInOut(board.CE0)
reset = digitalio.DigitalInOut(board.D24)
backlight = digitalio.DigitalInOut(board.D22)
backlight.switch_to_output()
backlight.value = False

display = adafruit_pcd8544.PCD8544(spi, dc, cs, reset)
display.bias = 5
contr = 48
display.contrast = contr
display.invert = True
display.fill(1)
display.show()

# Button Def
prev_btn = digitalio.DigitalInOut(board.D27)
next_btn = digitalio.DigitalInOut(board.D18)
yes_btn = digitalio.DigitalInOut(board.D17)
no_btn = digitalio.DigitalInOut(board.D25)

# Configure buttons with pull-up resistors
# Buttons connect GPIO to Ground when pressed
prev_btn.switch_to_input(pull=digitalio.Pull.UP)
next_btn.switch_to_input(pull=digitalio.Pull.UP)
yes_btn.switch_to_input(pull=digitalio.Pull.UP)
no_btn.switch_to_input(pull=digitalio.Pull.UP)

# Initialize function instance
functions = function(prev_btn, next_btn, yes_btn, no_btn, backlight, display, contr)

menu = [
    "       Time      ",
    "       Date      ",
    "      Upgrade    ",
    "      Network    ",
    "    Temperature  ",
    "        CPU      ",
    "        RAM      ",
    "       DISK      ",
    "     Back LED    ",
    "     Contrast    ",
    "      Volume     ",
    "     Shutdown    ",
    "      Restart    "]

img_files = [
    "time.bmp",
    "calendar.bmp",
    "upgrade.bmp",
    "network.bmp",
    "temperature.bmp",
    "cpu.bmp",
    "ram.bmp",
    "disk.bmp",
    "bkled.bmp",
    "contrast.bmp",
    "volume.bmp",
    "shutdown.bmp",
    "restart.bmp"]

# Pre-load and cache all images for better performance
print("Loading images...")
cached_images = []
for img_file in img_files:
    img = Image.open('images/' + img_file).resize(
        (display.width, display.height),
        Image.Resampling.LANCZOS
    ).convert('1')
    cached_images.append(img)

# Pre-load font
font = ImageFont.truetype('fonts/EnterCommand.ttf', 15)

# Direct function mapping (faster than eval)
func_map = [
    functions.get_time,
    functions.get_date,
    functions.sys_upgrade,
    functions.get_ip,
    functions.get_cpu_temperature,
    functions.get_cpu,
    functions.get_ram,
    functions.get_disk,
    functions.toggleBkled,
    functions.set_contrast,
    functions.set_volume,
    functions.shutdown,
    functions.restart
]

head = None
body = None
msg = None
option = 0
btn_pressed = False
command = "no"
last_update_time = 0
UPDATE_INTERVAL = 0.1  # Update display every 100ms

print("Starting main loop...")
while True:
    current_time = time.time()
    needs_update = False

    # Handle button input with debouncing
    if not btn_pressed:
        if not next_btn.value:
            btn_pressed = True
            command = ""
            option = (option + 1) % len(menu)
            needs_update = True
        elif not prev_btn.value:
            btn_pressed = True
            command = ""
            option = (option - 1) % len(menu)
            needs_update = True
        elif not yes_btn.value:
            btn_pressed = True
            command = "yes"
            needs_update = True
        elif not no_btn.value:
            btn_pressed = True
            command = "no"
            needs_update = True

    # Reset button pressed state when all buttons are released
    if btn_pressed and functions.no_button_pressed():
        btn_pressed = False

    # Update display at regular intervals or when button pressed
    if needs_update or (current_time - last_update_time >= UPDATE_INTERVAL):
        # Call the function directly (much faster than eval)
        msg, body = func_map[option](command)
        head = menu[option]

        # Copy cached image (faster than loading from disk)
        image = cached_images[option].copy()
        draw = ImageDraw.Draw(image)

        # Draw text on image
        draw.text((0, 1), head, font=font)
        draw.text((0, 36), body, font=font)
        draw.text((25, 13), msg, font=font)

        # Update display
        display.image(image)
        display.show()

        last_update_time = current_time
        needs_update = False

    # Short sleep to prevent CPU spinning
    time.sleep(0.02)  # 20ms - faster response time
